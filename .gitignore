# Node
node_modules/
dist/
*.log

# Rust (will be relevant once Slice 1 lands)
target/
Cargo.lock.*

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Sandcastle local state
.sandcastle/logs/
.sandcastle/worktrees/
.sandcastle/.env

# PDO local state — runtime DB, per-run worktrees, library, prompt
# snapshots. All per-user; never committed — EXCEPT the builtin seed
# pipelines below, which build.rs embeds via include_str!; they must be in
# git so a fresh checkout (CI / new clone) compiles.
.pdo/*
!.pdo/pipelines/
.pdo/pipelines/*
!.pdo/pipelines/review-loop.yaml
!.pdo/pipelines/simple-bugfix.yaml
!.pdo/pipelines/planner.yaml

# Playwright artefacts
frontend/test-results/
frontend/playwright-report/
frontend/playwright/.cache/
.playwright-mcp/

# Local design prompt scratchpad — not shared
design-prompts/

# Throwaway UI prototypes — local-only dev scaffolding, wired via the
# main.tsx prototype gate (/?prototype=…). Never shared.
frontend/src/prototype/

# Reproduction / debugging screenshots dropped at the repo root
/*.png

# Personal agent context — not shared with the team
CLAUDE.local.md

# Env files at any path
.env
.env.local
